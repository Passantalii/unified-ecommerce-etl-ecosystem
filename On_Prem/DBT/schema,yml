version: 2

models:


  - name: stg_customer
    description: "Staging table for customer data, sourced from raw_customers."

    columns:

      - name: customer_id
        description: "Original customer ID from source system."
        tests:
          - not_null

      - name: name
        description: "Customer full name."

      - name: email
        description: "Customer email address."

      - name: gender
        description: "Customer gender."
      
      - name: signup_date
        description: "Date when customer signed up."

      - name: country
        description: "Customer country."

  - name: stg_order_items
    description: "Staging table for order_items data, sourced from raw_order_items."

    columns:

      - name: order_item_id
        description: "Original order ID from source system."
        tests:
          - not_null

      - name: order_id
        description: "Original order ID from source system."
        tests:
          - not_null

      - name: product_id
        description: "Original product ID from source system."
        tests:
          - not_null

      - name: order_quantity
        description: "Quantity of the product ordered."
        tests:
          - not_null

      - name: unit_price
        description: "Unit price of the product."
        tests:
          - not_null

  - name: stg_orders
    description: "Staging table for orders data, sourced from raw_orders."
  
    columns:

      - name: order_id
        description: "Original order ID from source system."
        tests:
          - not_null

      - name: customer_id
        description: "Original customer ID from source system."
        tests:
          - not_null

      - name: product_id
        description: "Original product ID from source system."
        tests:
          - not_null

      - name: order_date
        description: "Date when the order was placed."
        tests:
          - not_null

      - name: total_amount
        description: "Total amount for the order."  
        tests:
          - not_null

      - name: payment_method
        description: "Payment method used for the order."
        tests:
          - not_null
      
      - name: shipping_country
        description: "Country where the order is shipped."
        tests:
          - not_null

  - name: stg_product_reviews
    description: "Staging table for reviews products, sourced from product_reviews."

    columns:

      - name: review_id
        description: "Original review ID from source system."
        tests:
          - not_null

      - name: product_id
        description: "Original product ID from source system."
        tests:
          - not_null

      - name: customer_id
        description: "Original customer ID from source system."
        tests:
          - not_null

      - name: rating
        description: "Review rating score."
        tests:
          - not_null

      - name: review_text
        description: "Customer review text."
        tests:
          - not_null

      - name: review_date
        description: "Date when the review was submitted."
        tests:
          - not_null
      

  - name: stg_products
    description: "Staging table for product data, sourced from raw_products."

    columns:

      - name: product_id
        description: "Surrogate primary key for product dimension."
        tests:
          - not_null
          - unique

      - name: product_name
        description: "Name of the product."

      - name: category
        description: "Product category."

      - name: price
        description: "Current product price."

      - name: stock_quantity
        description: "Current stock quantity available."
        tests:
          - not_null

      - name: product_brand
        description: "Product brand."
      - tests:
          - not_null
